{
  "name": "@looopy-ai/examples",
  "version": "1.0.0",
  "description": "RxJS-based AI agent framework implementing the A2A protocol",
  "type": "module",
  "scripts": {
    "check:exports": "pnpx ts-unused-exports ./tsconfig.json --excludePathsFromReport='index'",
    "check:types": "tsc --noEmit",
    "agentcore:server": "tsx src/agentcore-server.ts",
    "agentcore:client": "tsx src/agentcore-client.ts",
    "example": "tsx src/kitchen-sink.ts",
    "kitchen-sink": "tsx src/kitchen-sink.ts",
    "input-required": "tsx src/input-required.ts",
    "server": "tsx src/sse-server.ts",
    "client2": "tsx src/sse-client2.ts",
    "example:litellm": "tsx src/litellm-agent.ts",
    "lint": "biome check src",
    "lint:fix": "biome check --write src"
  },
  "keywords": [
    "agent",
    "ai",
    "rxjs",
    "a2a",
    "llm"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.6.5",
  "dependencies": {
    "@geee-be/sse-stream-parser": "^1.0.2",
    "@hono/node-server": "^2.0.1",
    "@looopy-ai/aws": "workspace:*",
    "@looopy-ai/core": "workspace:*",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.216.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.216.0",
    "@opentelemetry/instrumentation": "^0.216.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "hono": "^4.12.16",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@langfuse/client": "^5.2.0"
  }
}
