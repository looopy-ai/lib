{
  "name": "looopy-ai",
  "version": "1.0.0",
  "description": "RxJS-based AI agent framework implementing the A2A protocol",
  "main": "src/core/index.ts",
  "type": "module",
  "scripts": {
    "check:all": "pnpm -r prepare && pnpm check:types && pnpm lint:fix && pnpm test",
    "check:types": "pnpm -r check:types",
    "test": "pnpm -r test",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "build": "pnpm -r --if-present build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "changes": "changeset",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r publish --filter '@looopy-ai/*' --filter '!@looopy-ai/examples' --no-git-checks"
  },
  "keywords": [
    "agent",
    "ai",
    "rxjs",
    "a2a",
    "llm"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "pino": "^10.3.1",
    "rxjs": "^7.8.2",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@changesets/cli": "^2.31.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "chalk": "^5.6.2",
    "dotenv": "^17.4.2",
    "eventsource": "^4.1.0",
    "mathjs": "^15.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
